class InstructionCSTNode(CSTNode):

    def __init__(self, mnemonic: Mnemonic, operands: list[OperandCSTNode], line_number:int=0, column_number:int=0) -> None:

        self.mnemonic = mnemonic
        self.operands = operands
        self.line_number = line_number
        self.column_number = column_number
    
    @classmethod
    def parse(cls, tokens: TokenStream) -> Self | Traceback:

        if not tokens:
            return Traceback.new("Instruction must not be empty.")
        if not tokens.tokens[0].value:
            return Traceback.new("Instruction must have a mnemoric", tokens.tokens[0].line_number, tokens.tokens[0].column_number)
        try:
            mnemonic = Mnemonic(str(tokens.tokens[0].value).lower())
        except ValueError:
            return Traceback.new(f"Unknown mnemonic '{tokens.tokens[0].value}'", tokens.tokens[0].line_number, tokens.tokens[0].column_number)
        
        operands: list[OperandCSTNode] = []
        index = 1
        while index < len(tokens):
            result = parse_operand(TokenStream(tokens.tokens[index:]))
            if isinstance(result.data, OperandCSTNode):
                operands.append(result.data)
                index += result.tokens_consumed
            elif isinstance(result.data, str):
                error = Traceback.new(result.data, tokens.tokens[index].line_number, tokens.tokens[index].column_number)
                error.elaborate("Invalid operand")
                return error
            else:
                return Traceback.new("Invalid operand", tokens.tokens[index].line_number, tokens.tokens[index].column_number)
        
        return InstructionCSTNode(mnemonic, operands, tokens.tokens[0].line_number, tokens.tokens[0].column_number)
    
    def __str__(self) -> str:
        
        operands = " ".join([str(operand).replace("\n", r"\n") for operand in self.operands])
        return f"{self.mnemonic.value} {operands}"

Line = InstructionCSTNode | Terminal[Label] | Terminal[Header]


def parse_line(line: TokenStream, macros: dict[str, list[Token]]) -> Line | Traceback | None | dict[str, list[Token]]:
            
    tokens = line.tokens
    if not tokens:
        return None
    
    if tokens[0].type == TokenType.LABEL:
        if not tokens[0].value:
            return Traceback.new(f"Label must not be empty", tokens[0].line_number, tokens[0].column_number)
        if len(tokens) > 1:
            return Traceback.new(f"Unexpected {tokens[1].type.value} after label .{tokens[0].value}", tokens[1].line_number, tokens[1].column_number)
        return Terminal(Label(str(tokens[0].value)), tokens[0].line_number, tokens[0].column_number)
    
    elif tokens[0].type == TokenType.MACRO:
        if not isinstance(tokens[0].value, str):
            return Traceback.new(f"Malformed macro token has non-str value (?)", tokens[0].line_number, tokens[0].column_number)
        if tokens[0].value.upper() != "DEFINE":
            print(f"Warning: Top-level macro @{tokens[0].value.upper()} on line {tokens[0].line_number} is not known, ignored")
            return None
        if len(tokens) <3: # ❤
            return Traceback.new(f"Macro definition is too short, use the syntax @DEFINE WORD DEFINITION", tokens[0].line_number, tokens[0].column_number)
        if tokens[1].type != TokenType.IDENTIFIER:
            return Traceback.new(f"Expected identifier, found {tokens[1].type.value}", tokens[1].line_number, tokens[1].column_number)
        return {str(tokens[1].value): tokens[2:]}

    else:
        result_tokens: list[Token] = []
        for token in tokens:
            if token.type == TokenType.IDENTIFIER:
                macro_value = macros.get(str(token.value))
                if macro_value:
                    for macro_token in macro_value:
                        result_tokens.append(Token(macro_token.type, token.line_number, token.column_number, macro_token.value))
                else:
                    result_tokens.append(token)
            else:
                result_tokens.append(token)
    
    instruction = InstructionCSTNode.parse(TokenStream(result_tokens))
    if not isinstance(instruction, InstructionCSTNode):
        instruction.elaborate("Invalid instruction", tokens[0].line_number, tokens[0].column_number)
    
    return instruction
