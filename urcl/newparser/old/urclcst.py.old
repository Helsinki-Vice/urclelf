"This module takes a stream of URCL tokens and parses it into a concrete syntax tree"
import enum
from dataclasses import dataclass
from typing import Union, Generic, TypeVar, Self, Sequence
from abc import ABC, abstractmethod

from urcl.types import Mnemonic, Label, RelativeAddress, Character, Port, GeneralRegister, DefinedImmediate, BasePointer, StackPointer, Header
from urcl.lex import TokenType, TokenStream, Token
from error import Traceback

T = TypeVar("T")

class OperandType(enum.Enum):
    INTEGER = enum.auto()
    LABEL = enum.auto()
    GENERAL_REGISTER = enum.auto()
    CHARACTER = enum.auto()
    PORT = enum.auto()
    RELATIVE_ADDERESS = enum.auto()
    ARRAY = enum.auto()

@dataclass
class ParseResult(Generic[T]):
    data: T | str | None
    tokens_consumed: int

    @classmethod
    def miss(cls):
        return ParseResult(None, 0)

class CSTNode(ABC):
    line_number: int
    column_number: int
    source: str

    @abstractmethod
    def get_leaves(self) -> Sequence[Self]:
        ...
    
    @abstractmethod
    @classmethod
    def from_tokens(cls, tokens: TokenStream, macros: dict[str, list[Token]]={}) -> ParseResult[Self]:
        ...

@dataclass
class Terminal(Generic[T], CSTNode):
    value: T
    line_number: int
    column_number: int

    def get_leaves(self) -> Sequence[Self]:
        return []
    
    def __str__(self) -> str:
        return str(self.value)

@dataclass
class OperandCSTNode(CSTNode):
    line_number: int
    column_number: int
    source: str
    value: Label | GeneralRegister | int | RelativeAddress | Character | Port | DefinedImmediate | str | BasePointer | StackPointer | list[Self]

    def __str__(self) -> str:

        if isinstance(self.value, str):
            return f'"{self.value}"'
        elif isinstance(self.value, list):
            return f"[{' '.join([str(value) for value in self.value])}]"
        elif isinstance(self.value, Label):
            return f"{self.value}"
        else:
            return str(self.value)
    
    @classmethod
    def from_tokens(cls, tokens: TokenStream, macros: dict[str, list[Token]]={}):

        index = 0
    
        token = tokens.tokens[index]
        if token.type == TokenType.LABEL:
            return ParseResult(OperandCSTNode(token.line_number, token.column_number, "", Label(str(token.value))), 1)

        elif isinstance(token.value, GeneralRegister):
            return ParseResult(OperandCSTNode(token.line_number, token.column_number, "", token.value), 1)

        elif token.type == TokenType.INTEGER:
            if not isinstance(token.value, int):
                return ParseResult(f"Invalid integer: '{token.value}'", 0)
            return ParseResult(OperandCSTNode(token.line_number, token.column_number, "", token.value), 1)

        elif token.type == TokenType.RELATIVE_JUMP:
            if not isinstance(token.value, int):
                return ParseResult(f"Invalid relative jump: '{token.value}'", 0)
            return ParseResult(OperandCSTNode(token.line_number, token.column_number, "", RelativeAddress(token.value)), 1)

        elif token.type == TokenType.CHARACTER:
            if not isinstance(token.value, str) or not token.value:
                return ParseResult(f"Invalid character: '{token.value}'", 1)
            return ParseResult(OperandCSTNode(token.line_number, token.column_number, "", Character(token.value)), 1)

        elif token.type == TokenType.STRING:
            if not isinstance(token.value, str) or not token.value:
                return ParseResult(f"Invalid string: '{token.value}'", 1)
            return ParseResult(OperandCSTNode(token.line_number, token.column_number, "", token.value), 1)

        elif token.type == TokenType.IDENTIFIER:
            if not isinstance(token.value, str) or not token.value:
                return ParseResult(f"Invalid identifier: '{token.value}'", 1)
            if token.value.lower() == "bp":
                return ParseResult(OperandCSTNode(token.line_number, token.column_number, "", BasePointer()), 1)
            elif token.value.lower() == "sp":
                return ParseResult(OperandCSTNode(token.line_number, token.column_number, "", StackPointer()), 1)
            else:
                return ParseResult.miss()

        elif token.type == TokenType.PORT:
            if not isinstance(token.value, str) or not token.value:
                return ParseResult(f"Invalid Port: '{token.value}'", 1)
            port = Port.from_value(token.value)
            if port:
                return ParseResult(OperandCSTNode(token.line_number, token.column_number, "", port), 1)
            else:
                return ParseResult(f"Unknown Port: '{token.value}'", 1)

        elif token.type == TokenType.MACRO:
            if isinstance(token.value, str):
                try:
                    defined_immediate = DefinedImmediate(token.value.upper())
                except ValueError:
                    defined_immediate = None
            else:
                defined_immediate = None
            if not defined_immediate:
                return ParseResult(f"Invalid defined immediate: '{token.value}'", 1)
            return ParseResult(OperandCSTNode(token.line_number, token.column_number, " ", defined_immediate), 1)

        elif token.type == TokenType.LEFT_BRACKET:
            
            index += 1
            defined_values: list[OperandCSTNode] = []
            while index < len(tokens):
                token = tokens.tokens[index]
                if token.type == TokenType.RIGHT_BRACKET:
                    break
                list_item = cls.from_tokens(TokenStream(tokens.tokens[index:]))

                if isinstance(list_item.data, OperandCSTNode):
                    defined_values.append(list_item.data)
                else:
                    return ParseResult(f"Array contains invalid value at index {index}", 0)
                index += 1
            else:
                return ParseResult("Array literal was not closed", 0)

            return ParseResult(OperandCSTNode(tokens.tokens[0].line_number, tokens.tokens[0].column_number, "", defined_values), index + 1)

        return ParseResult.miss()

    def get_leaves(self) -> list[Self]:
        if isinstance(self.value, list):
            return self.value
        else:
            return []

@dataclass
class InstructionCSTNode(CSTNode):
    line_number: int
    column_number: int
    source: str
    mnemonic: Terminal[Mnemonic]
    operands: list[OperandCSTNode]

    def get_leaves(self):
        return [self.mnemonic] + self.operands

@dataclass
class HeaderCSTNode(CSTNode):
    
    line_number: int
    column_number: int
    source: str

    @abstractmethod
    def get_leaves(self) -> Sequence[Self]:
        ...
    
    @abstractmethod
    @classmethod
    def from_tokens(cls, tokens: TokenStream, macros:dict[str, list[Token]]={}) -> ParseResult[Self]:
        ...

@dataclass
class MacroCSTNode(CSTNode):
    
    line_number: int
    column_number: int
    source: str

    def get_leaves(self):
        ...
    
    @classmethod
    def from_tokens(cls, tokens: TokenStream, macros:dict[str, list[Token]]={}):
        ...

@dataclass
class LineCSTNode(CSTNode):
    line_number: int
    column_number: int
    source: str
    value: InstructionCSTNode | HeaderCSTNode | MacroCSTNode

    @classmethod
    def from_tokens(cls, tokens: TokenStream, macros:dict[str, list[Token]]={}) -> ParseResult[Self]:
        ...
    
    def get_leaves(self):
        return [self.value]
   
@dataclass
class CST(CSTNode):

    lines: list[LineCSTNode]
    
    @classmethod
    def from_tokens(cls, source: TokenStream):

        cst = CST([])
        macros: dict[str, list[Token]] = {}
        for line in source.split_lines():
            line_result = LineCSTNode.from_tokens(line, macros)
            if isinstance(line_result, dict):
                macros.update(line_result)
            elif isinstance(line_result, (InstructionCSTNode, Terminal)):
                cst.lines.append(line_result)
            elif isinstance(line_result, Traceback):
                error = line_result
                error.elaborate("Invalid line of URCL code")
            else:
                continue
        
        return cst
    
    def get_leaves(self):
        return self.lines
    
    def __str__(self) -> str:
        return "\n".join([str(line) for line in self.lines])

 
